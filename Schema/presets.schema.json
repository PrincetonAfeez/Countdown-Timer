{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/pytimer/presets.schema.json",
  "title": "pytimer presets.json",
  "description": "Schema for ~/.pytimer/presets.json, a map of preset names to duration strings.",
  "type": "object",
  "minProperties": 0,
  "additionalProperties": {
    "type": "string",
    "minLength": 1,
    "pattern": "^\\s*(?:\\d+(?:ms|s|m|h)(?:\\s*\\d+(?:ms|s|m|h))*|\\d{1,2}:\\d{2}(?::\\d{2})?|[A-Za-z0-9\\s-]+)\\s*$",
    "description": "Duration text accepted by the app, such as 25m, 1h30m, 5:00, or five minutes."
  },
  "propertyNames": {
    "type": "string",
    "minLength": 1,
    "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$"
  },
  "examples": [
    {
      "pomodoro": "25m",
      "tea": "4m",
      "standup": "15m"
    }
  ]
}
