{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/pytimer/config.schema.json",
  "title": "pytimer config.toml",
  "description": "Schema for the parsed object representation of ~/.pytimer/config.toml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tick_rate_hz": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 10.0,
      "description": "Timer refresh rate in ticks per second."
    },
    "renderer": {
      "type": "string",
      "enum": ["big", "minimal"],
      "default": "big",
      "description": "Terminal renderer to use."
    },
    "notifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["bell", "desktop"]
      },
      "uniqueItems": true,
      "default": ["bell"],
      "description": "Notification methods used when a timer finishes."
    },
    "color_scheme": {
      "type": "string",
      "default": "default",
      "description": "Named color scheme for terminal output."
    },
    "parser_order": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["compact", "colon", "natural"]
      },
      "minItems": 1,
      "uniqueItems": true,
      "default": ["compact", "colon", "natural"],
      "description": "Duration parser priority order."
    },
    "bell_volume": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 1.0,
      "description": "Relative bell volume, from 0.0 to 1.0."
    }
  }
}
